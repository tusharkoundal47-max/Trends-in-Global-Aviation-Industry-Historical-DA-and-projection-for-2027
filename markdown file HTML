const BLACK = "#000000";
const GREY = "#B5B5B5";
const ACCENT = "#0072CE";

function bar(ctx, labels, datasets, opts={}) {
  return new Chart(ctx, {type:'bar', data:{labels, datasets}, options:Object.assign({
    responsive:true, plugins:{legend:{display: datasets.length>1}}, scales:{y:{beginAtZero:true}}
  }, opts)});
}

// Chart 1: revenue + margin combo
new Chart(document.getElementById('chart1'), {
  data: {
    labels: D.years,
    datasets: [
      {type:'bar', label:'Revenue ($B)', data:D.rev, backgroundColor:GREEN, yAxisID:'y'},
      {type:'line', label:'Avg Operating Margin (%)', data:D.margin, borderColor:BLACK, backgroundColor:BLACK, yAxisID:'y1', tension:0.25, pointRadius:2}
    ]
  },
  options:{ responsive:true, interaction:{mode:'index',intersect:false},
    scales:{ y:{type:'linear',position:'left',title:{display:true,text:'$B'}}, y1:{type:'linear',position:'right',grid:{drawOnChartArea:false},title:{display:true,text:'%'}} }
  }
});

